# DB
# Local development: postgresql://postgres:postgres@localhost:5432/textube
# Railway: Railway PostgreSQL automatically provides DATABASE_URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/textube"

# Session
# IMPORTANT: Generate a strong random string for production
SESSION_SECRET=your-secret-key-change-this-in-production

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Development: http://localhost:4000/auth/google/callback
# Production: https://your-app.railway.app/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# App URLs
# Development
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
# Production (Railway example)
# APP_URL=https://your-app.railway.app
# FRONTEND_URL=https://your-frontend.vercel.app

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# YouTube Data API
YOUTUBE_API_KEY=your-youtube-api-key
