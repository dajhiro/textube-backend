# DB
# Local development: postgresql://postgres:postgres@localhost:5432/textube
# Railway: Railway PostgreSQL automatically provides DATABASE_URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/textube"

# Session
# IMPORTANT: Generate a strong random string for production
SESSION_SECRET=your-secret-key-change-this-in-production

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Development: http://localhost:4000/auth/google/callback
# Production: https://api.textube.io/auth/google/callback (via Cloudflare CNAME)
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# Environment
NODE_ENV=development

# Frontend URL (for CORS and redirects)
# Development
FRONTEND_URL=http://localhost:3000
# Production (Cloudflare)
# FRONTEND_URL=https://textube.io

# CORS Allowed Origins (comma-separated)
# Development: Allow localhost variants
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production: Only allow production domains
# CORS_ORIGINS=https://textube.io,https://www.textube.io

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# YouTube Data API
YOUTUBE_API_KEY=your-youtube-api-key
